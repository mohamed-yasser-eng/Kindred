# Server
PORT=5000
CLIENT_ORIGINS=http://localhost:3000,http://localhost:5173

# Database
DB_URL_LOCAL=mongodb://localhost:27017/Social-app-backend

# Hashing
SALT_ROUNDS=10

# Encryption
IV_LENGTH=16
ENCRYPTION_SECRET_KEY=replace_with_32_character_secret

# Email
USER_EMAIL=your_email@gmail.com
USER_EMAIL_PASSWORD=your_gmail_app_password

# JWT
JWT_ACCESS_SECRET=replace_with_access_secret
JWT_ACCESS_EXPIRES_IN=1d
JWT_PREFIX=Bearer
JWT_REFRESH_SECRET=replace_with_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_KEY_FOLDER=social-app
AWS_S3_BUCKET_NAME=social-app-bucket

# Redis
REDIS_URL=redis://127.0.0.1:6379
